---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import dayjs from "dayjs";

const blogPosts = (await getCollection("blog")).filter((post) => !post.data.draft);

blogPosts.sort((a, b) => b.slug?.localeCompare(a?.slug || "") || 0);

const { limit } = Astro.props;
---

<div class="container">
  <h2 class="font-bold text-accent text-2xl lg:text-3xl uppercase tracking-widest">Blog</h2>
  <p class="text-text-secondary text-sm lg:text-base max-w-xl mt-1">
    A collection of photos, web dev & personal improvement
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-8">
    {
      blogPosts.slice(0, limit).map((post) => {
        const date = dayjs(post.id.substring(0, 10)).format("MMM D, YYYY");
        return (
          <a
            href={`/blog/${post.slug}`}
            class="group relative block overflow-hidden rounded-xl bg-surface border border-border transition-transform duration-300 hover:scale-[1.01] not-prose"
          >
            {post.data.image ? (
              <>
                <div class="aspect-square">
                  <Image
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    widths={[400, 800]}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  />
                </div>
                <div class="card-scrim absolute inset-x-0 bottom-0 pt-20 pb-5 px-5">
                  <span class="text-accent font-thin text-xs">{date}</span>
                  <h3 class="text-white text-lg font-semibold mt-1 leading-tight">{post.data.title}</h3>
                </div>
              </>
            ) : (
              <div class="aspect-square p-5 flex flex-col">
                <span class="text-accent font-thin text-xs">{date}</span>
                <h3 class="text-text-primary text-lg font-semibold mt-2 leading-snug">{post.data.title}</h3>
                <p class="text-text-secondary text-sm mt-2 line-clamp-4">{post.data.summary}</p>
              </div>
            )}
          </a>
        );
      })
    }
  </div>
</div>
