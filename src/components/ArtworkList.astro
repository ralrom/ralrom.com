---
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  limit?: number;
  artworkItems?: CollectionEntry<"artwork">[];
}

const { limit, artworkItems } = Astro.props;

let artwork: CollectionEntry<"artwork">[];
if (artworkItems) {
  artwork = artworkItems;
} else {
  artwork = (await getCollection("artwork")).filter((artwork) => !artwork.data.draft);
  artwork.sort((a, b) => b.slug?.localeCompare(a?.slug || "") || 0);
}

const items = artwork.slice(0, limit);
---

<div class="container">
  <div class="mb-8">
    <h2 class="font-bold text-accent text-2xl lg:text-3xl uppercase tracking-widest">Artwork</h2>
    <p class="text-text-secondary text-sm lg:text-base max-w-xl mt-1">
      A Showcase of My Artwork, Hobby Projects & Learning
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {
      items.map((artworkItem) => (
        <a
          href={`/artwork/${artworkItem.slug}`}
          class="group relative overflow-hidden rounded-xl bg-surface border border-border block transition-transform duration-300 hover:scale-[1.02]"
        >
          <div class="aspect-square">
            <Image
              src={artworkItem.data.image}
              width={620}
              height={620}
              alt={artworkItem.data.title}
              class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="card-scrim absolute inset-x-0 bottom-0 pt-16 pb-4 px-4">
            <p class="text-white font-semibold text-base lg:text-lg leading-tight">{artworkItem.data.title}</p>
            {artworkItem.data.medium && <p class="text-accent font-thin text-xs mt-0.5">{artworkItem.data.medium}</p>}
          </div>
        </a>
      ))
    }
  </div>
</div>
